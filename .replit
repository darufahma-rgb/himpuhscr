modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Scraper HIMPUH"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Dashboard HIMPUH"

[[workflows.workflow]]
name = "Scraper HIMPUH"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node /home/runner/workspace/scraper/scrape-himpuh.js"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Dashboard HIMPUH"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node /home/runner/workspace/scraper/server.js"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "webview"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000
